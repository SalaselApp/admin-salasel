# 'development' = local Docker Supabase, anything else = cloud (PROD_* vars)
APP_ENV=development

# Single shared admin password for logging into this app.
ADMIN_PASSWORD=replace-with-a-strong-password

# Secret used to sign the session cookie (JWT). Generate with:
#   openssl rand -base64 32
SESSION_SECRET=replace-with-a-random-32-byte-secret

# Name of the session cookie.
COOKIE_NAME=salasel_admin_session

# Session lifetime, in days.
SESSION_DURATION=7

# Failed login attempts before a client is locked out.
MAX_ATTEMPTS=5

# Lockout duration, in milliseconds.
LOCKOUT_MS=60000

DEV_SUPABASE_URL=http://127.0.0.1:54321
DEV_SUPABASE_ANON_KEY=replace-with-local-anon-key
DEV_SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

PROD_SUPABASE_URL=https://your-project.supabase.co
PROD_SUPABASE_ANON_KEY=replace-with-prod-anon-key
PROD_SUPABASE_SERVICE_ROLE_KEY=replace-with-prod-service-role-key
